# AI 러닝 코치(Claude)에 필요한 Anthropic API 키입니다.
# 키 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- 배포(Vercel + Turso) 시에만 필요 ---
# 로컬에서는 비워두면 data/running.db 파일을 사용합니다.
# Turso DB 생성 후 값 채우기: https://turso.tech
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# (선택) 공개 배포 시 /api/health 보호용 토큰.
# 설정하면 Health Auto Export "헤더 추가"에 x-ingest-token: <값> 을 넣어야 합니다.
INGEST_TOKEN=
